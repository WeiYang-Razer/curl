{
  "name": "curl",
  "version": "8.19.0.2",
  "schemaVersion": 2,
  "kind": "StaticLib",
  "description": "Client-side URL transfer library (HTTP/FTP/SMTP/...)",
  "dependencies": {},
  "build": {
    "system": "cmake",
    "configs": [
      "Debug",
      "Release",
      "RelWithDebInfo",
      "MinSizeRel"
    ],
    "configure": [
      "-DBUILD_CURL_EXE=OFF",
      "-DBUILD_SHARED_LIBS=OFF",
      "-DBUILD_STATIC_LIBS=ON",
      "-DBUILD_TESTING=OFF",
      "-DBUILD_EXAMPLES=OFF",
      "-DBUILD_LIBCURL_DOCS=OFF",
      "-DBUILD_MISC_DOCS=OFF",
      "-DPICKY_COMPILER=OFF",
      "-DCURL_USE_LIBPSL=OFF",
      "-DCURL_USE_SCHANNEL=ON",
      "-DCURL_USE_OPENSSL=OFF",
      "-DCMAKE_DEBUG_POSTFIX=d",
      "-DCMAKE_RELWITHDEBINFO_POSTFIX=rd",
      "-DCMAKE_MINSIZEREL_POSTFIX=msr"
    ],
    "installDir": "install"
  }
}
